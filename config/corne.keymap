/*
 * Optimized Corne Keymap for Mike Carey - v2.1
 * Optimizations: Markdown/prose editing, app switching (Raycast), Obsidian navigation
 * PRIMARY WORKFLOWS: Slack messages, Linear tickets, Obsidian docs, Terminal (claude)
 * CHANGES FROM v2.0:
 *   - Colon on base layer home row (replaced semicolon) for emoji usage
 *   - Word-jump navigation: Shift+H/L = Option+Left/Right (word backward/forward)
 * Generated: 2026-06-09
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    // Define macros for app switching via Raycast
    // Each sends Cmd+Ctrl+Opt+Shift+[key] for Raycast to intercept
    macros {
        app_warp: app_warp {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LC(LA(LS(A))))>;
        };
        app_slack: app_slack {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LC(LA(LS(S))))>;
        };
        app_notion: app_notion {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LC(LA(LS(D))))>;
        };
        app_linear: app_linear {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LC(LA(LS(F))))>;
        };
        app_zen: app_zen {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LC(LA(LS(J))))>;
        };
        app_arc: app_arc {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LC(LA(LS(K))))>;
        };
        // Word-jump macros for terminal/editor navigation
        word_left: word_left {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LA(LEFT)>;  // Option+Left = word backward
        };
        word_right: word_right {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LA(RIGHT)>;  // Option+Right = word forward
        };
    };

    // Conditional layer: APP layer activates when LOWER + RAISE held together
    conditional_layers {
        compatible = "zmk,conditional-layers";
        app_layer {
            if-layers = <1 2>;  // If layers 1 (LOWER) and 2 (RAISE) both active
            then-layer = <3>;    // Activate layer 3 (APP)
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ============================================
        // LAYER 0: BASE - QWERTY (colon on home row for emoji usage)
        // ============================================
        default_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  Q  |  W  |  E  |  R  |  T  |   |  Y  |  U   |  I  |  O  |  P  | BSPC |
            // | CTRL |  A  |  S  |  D  |  F  |  G  |   |  H  |  J   |  K  |  L  |  :  |  '   |
            // | SHFT |  Z  |  X  |  C  |  V  |  B  |   |  N  |  M   |  ,  |  .  |  /  | ESC  |
            //                    | GUI | LWR | SPC |   | ENT | RSE  | ALT |

            bindings = <
   &kp TAB   &kp Q &kp W &kp E &kp R &kp T   &kp Y &kp U  &kp I     &kp O   &kp P    &kp BSPC
   &kp LCTRL &kp A &kp S &kp D &kp F &kp G   &kp H &kp J  &kp K     &kp L   &kp COLON &kp SQT
   &kp LSHFT &kp Z &kp X &kp C &kp V &kp B   &kp N &kp M  &kp COMMA &kp DOT &kp FSLH &kp ESC
                  &kp LGUI &mo 1 &kp SPACE   &kp RET &mo 2 &kp RALT
            >;
        };

        // ============================================
        // LAYER 1: LOWER - Numbers + Navigation + Word-Jump
        // Left: Linear numbers for ticket IDs, dates
        // Right: Vim-style arrows (HJKL) for Obsidian doc navigation
        //        + Shift modifier for word-jump (Shift+H/L = word left/right)
        // ============================================
        lower_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  1  |  2  |  3  |  4  |  5  |   |  6  |  7   |  8  |  9  |  0  | BSPC |
            // | BTCLR| BT1 | BT2 | BT3 | BT4 | BT5 |   | LFT | DWN  |  UP | RGT | HOME| END  |
            // | SHFT |     |     |     |     |     |   | PGUP| PGDN | W←  | W→  |     |      |
            //                    | GUI |     | SPC |   | ENT |      | ALT |
            // Note: Shift+H = word left, Shift+L = word right when LOWER is active

            bindings = <
   &kp TAB    &kp N1       &kp N2       &kp N3       &kp N4       &kp N5         &kp N6    &kp N7    &kp N8      &kp N9       &kp N0   &kp BSPC
   &bt BT_CLR &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4   &kp LEFT  &kp DOWN  &kp UP      &kp RIGHT    &kp HOME &kp END
   &kp LSHFT  &trans       &trans       &trans       &trans       &trans         &kp PG_UP &kp PG_DN &word_left  &word_right  &trans   &trans
                                        &kp LGUI     &trans       &kp SPACE      &kp RET   &trans    &kp RALT
            >;
        };

        // ============================================
        // LAYER 2: RAISE - Markdown Symbols (semicolon moved here from base)
        // Optimized for: Slack, Linear, Obsidian, markdown editing
        // High-frequency: backtick (code blocks), #, -, brackets
        // ============================================
        raise_layer {
            // -----------------------------------------------------------------------------------------
            // |  TAB |  !  |  @  |  #  |  $  |  %  |   |  ^  |  &  |  *  |  `  |  ~  | BSPC |
            // | CTRL |  [  |  ]  |  (  |  )  |  -  |   |  =  |  ;  |  "  |  '  |  \  |  `   |
            // | SHFT |  {  |  }  |  <  |  >  |  _  |   |  +  |  |  |     |     |     |      |
            //                    | GUI |     | SPC |   | ENT |     | ALT |

            bindings = <
   &kp TAB   &kp EXCL &kp AT   &kp HASH &kp DLLR &kp PRCNT   &kp CARET &kp AMPS &kp ASTRK &kp GRAVE &kp TILDE &kp BSPC
   &kp LCTRL &kp LBKT &kp RBKT &kp LPAR &kp RPAR &kp MINUS   &kp EQUAL &kp SEMI &kp DQT   &kp SQT   &kp BSLH  &kp GRAVE
   &kp LSHFT &kp LBRC &kp RBRC &kp LT   &kp GT   &kp UNDER   &kp PLUS  &kp PIPE &trans    &trans    &trans    &trans
                              &kp LGUI &trans &kp SPACE        &kp RET &trans &kp RALT
            >;
        };

        // ============================================
        // LAYER 3: APP - Application Switching (via Raycast)
        // Activated when LOWER + RAISE held together
        // Home row = app launcher (sends Cmd+Ctrl+Opt+Shift+key)
        // ============================================
        app_layer {
            // -----------------------------------------------------------------------------------------
            // |      |     |     |     |     |     |   |     |     |     |     |     |      |
            // |      | WARP|SLACK|NOTN |LINR |     |   |     | ZEN | ARC |     |     |      |
            // |      |     |     |     |     |     |   |     |     |     |     |     |      |
            //                    |     |     |     |   |     |     |     |

            bindings = <
   &trans &trans     &trans     &trans      &trans      &trans   &trans &trans    &trans   &trans &trans &trans
   &trans &app_warp  &app_slack &app_notion &app_linear &trans   &trans &app_zen  &app_arc &trans &trans &trans
   &trans &trans     &trans     &trans      &trans      &trans   &trans &trans    &trans   &trans &trans &trans
                                &trans      &trans      &trans   &trans &trans    &trans
            >;
        };
    };
};
